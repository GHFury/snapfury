# ─────────────────────────────────────────────────────────────
#  SNAP FURY — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# ─── DATABASE (Neon PostgreSQL) ──────────────────────────────
# Get a free DB at https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAUTH PROVIDERS ─────────────────────────────────────────

# Google → https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord → https://discord.com/developers/applications
# Redirect URI: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Twitch → https://dev.twitch.tv/console/apps
# Redirect URI: http://localhost:3000/api/auth/callback/twitch
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ─── SUPABASE (Storage — video file uploads) ─────────────────
# Project URL and keys from: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# Storage bucket name (create in Supabase → Storage)
STORAGE_BUCKET_NAME="snapfury-clips"

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Max video upload size in bytes (default 500MB)
MAX_UPLOAD_SIZE=524288000

# ─── SNAP OF THE WEEK ────────────────────────────────────────
# Comma-separated list of admin emails that can pick the SOTW winner
ADMIN_EMAILS="you@example.com"

# ─────────────────────────────────────────────────────────────
#  PRODUCTION (Vercel)
#  Set all of the above in: Vercel Dashboard → Project → Settings → Environment Variables
#  Change NEXTAUTH_URL to your real domain e.g. https://snapfury.com
#  Change NEXT_PUBLIC_APP_URL to your real domain as well
# ─────────────────────────────────────────────────────────────
