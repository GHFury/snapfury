# ─── DATABASE ───────────────────────────────────────────────
# Get a free PostgreSQL DB at https://supabase.com or https://railway.app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/snapfury?schema=public"

# ─── NEXTAUTH ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAUTH PROVIDERS ─────────────────────────────────────────
# Google  → https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord → https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Twitch  → https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ─── STORAGE (video uploads) ─────────────────────────────────
# AWS S3 or Cloudflare R2 (R2 is cheaper & S3-compatible)
# R2 → https://dash.cloudflare.com/r2
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="snapfury-clips"

# Public CDN URL for your bucket
NEXT_PUBLIC_CDN_URL="https://clips.snapfury.com"

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Max upload size in bytes (default 500MB)
MAX_UPLOAD_SIZE=524288000

# ─── SNAP OF THE WEEK ────────────────────────────────────────
# Comma-separated admin emails that can pick the SOTW winner
ADMIN_EMAILS="you@example.com"
